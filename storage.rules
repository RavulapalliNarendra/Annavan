rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /crops/{allPaths=**} {
      // Allow read access to everyone
      allow read: if true;
      // Allow write access only to authenticated users (farmers)
      // Ideally restrict to farmers only via custom claims or firestore lookup, 
      // but for simple storage rules, auth check is often sufficient for mvp.
      allow write: if request.auth != null;
    }
  }
}
