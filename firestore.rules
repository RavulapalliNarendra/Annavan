rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is a farmer
    function isFarmer() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'farmer';
    }

    // User Profiles
    match /users/{userId} {
      // Allow users to read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // Allow creation during signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Allow users to update their own profile
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }

    // Crops
    match /crops/{cropId} {
      // Anyone can read crops (for marketplace)
      allow read: if true;
      // Only authenticated farmers can create crops
      allow create: if isFarmer() && request.resource.data.farmerId == request.auth.uid;
      // Farmers can update/delete their own crops
      allow update, delete: if isAuthenticated() && resource.data.farmerId == request.auth.uid;
    }

    // Orders
    match /orders/{orderId} {
      // Readers: Buyer or Farmer involved in the order
      allow read: if isAuthenticated() && 
        (resource.data.farmerId == request.auth.uid || resource.data.buyerId == request.auth.uid);
      
      // Create: Only authenticated users can create (Buyers)
      allow create: if isAuthenticated() && request.resource.data.buyerId == request.auth.uid;
      
      // Update: 
      // Farmers can update 'status', 'acceptedAt', 'rejectedAt' ONLY if they are the farmer of the order
      allow update: if isAuthenticated() && resource.data.farmerId == request.auth.uid && 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'rejectedAt']));
    }
  }
}
